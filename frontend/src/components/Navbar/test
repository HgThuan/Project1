.topbar {
  background-color: #2f2f2f;
  color: #fff;
  font-size: 14px;
  padding: 6px 0;
  border-bottom: 1px solid #3a3a3a;
}

.topbar__inner {
  max-width: 1320px; /* rộng hơn chút để dịch sang phải */
  margin: 0 auto;
  display: flex;
  justify-content: flex-end;
  align-items: center;
  padding: 0 40px; /* dịch toàn bộ sang phải */
}

.topbar__right {
  display: flex;
  align-items: center;
  gap: 28px; /* giãn cách đều giữa các mục */
}

.topbar__item {
  color: #eaeaea;
  text-decoration: none;
  display: flex;
  align-items: center;
  gap: 6px;
  transition: color 0.2s ease;
  font-weight: 400;
}

.topbar__item:hover {
  color: #ffffff;
}

.topbar__item i {
  font-size: 15px;
  opacity: 0.9;
}

/* Căn chỉnh hiển thị tốt hơn trên màn nhỏ */
@media (max-width: 768px) {
  .topbar__inner {
    justify-content: center;
    padding: 0 10px;
  }
  .topbar__right {
    gap: 16px;
    flex-wrap: wrap;
  }
  .topbar__item {
    font-size: 13px;
  }
}
